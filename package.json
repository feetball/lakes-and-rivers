    "@types/react-dom": "^18.3.7",
    "@types/recharts": "^1.8.29",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "npm": "^11.12.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "semver": "^7.7.4"
  },
