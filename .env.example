# Admin credentials for cache management
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_secure_password_123

# Shared secret for preload service authentication (required for Docker deployments)
PRELOAD_SECRET=change_this_to_a_random_secret

# CORS allowed origins (comma-separated, leave empty to allow all)
# CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Allow live USGS API fetching (set to 'true' to enable live data, 'false' for cache-only)
ALLOW_LIVE_USGS_FETCH=true

# Redis connection (optional, for caching)
# REDIS_URL=redis://localhost:6379